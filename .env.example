# Copy this file to .env and fill in your values.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rescuer_locator
POSTGRES_USER=rescuer
POSTGRES_PASSWORD=change_me

# ── Backend ───────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LOCATION_RETENTION_DAYS=5 # a background task runs daily and deletes events older than LOCATION_RETENTION_DAYS

# ── Weather overlay (OpenWeatherMap) ─────────────────────────
# Get a free key at https://openweathermap.org/api
VITE_OWM_API_KEY=

# ── Serial reader ─────────────────────────────────────────────
# 1. Set SERIAL_PORT in your .env — on macOS it'll be something like /dev/cu.usbserial-XXXX (run ls /dev/cu.* to find it)
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=9600
