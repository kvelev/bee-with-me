# Copy this file to .env and fill in your values.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rescuer_locator
POSTGRES_USER=rescuer
POSTGRES_PASSWORD=change_me

# ── Backend ───────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
REFRESH_TOKEN_EXPIRE_DAYS=7
LOCATION_RETENTION_DAYS=90  # background task deletes location_events older than this many days

# ── Weather overlay (OpenWeatherMap) ─────────────────────────
# Get a free key at https://openweathermap.org/api
VITE_OWM_API_KEY=

# ── Serial reader ─────────────────────────────────────────────
# On macOS run `ls /dev/cu.*` to find the port name
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=9600

# ── HID reader ────────────────────────────────────────────────
# USB HID gateway VID and PID (hexadecimal)
HID_VENDOR_ID=0x0ACD
HID_PRODUCT_ID=0xFAAF
